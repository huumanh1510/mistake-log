  // ---- Notion-like table widget ----
  function buildTableWidget(initialRows, initialCols){
    const outer = document.createElement('div');
    outer.className = 'q-table-outer';
    outer.contentEditable = 'false';

    const flexRow = document.createElement('div');
    flexRow.className = 'q-table-flex';

    const table = document.createElement('table');
    table.className = 'q-table';

    const colgroup = document.createElement('colgroup');
    const ctrlCol = document.createElement('col');
    ctrlCol.className = 'q-ctrl-col-def';
    ctrlCol.style.width = '16px';
    colgroup.appendChild(ctrlCol);
    for(let c=0; c<initialCols; c++){
      const col = document.createElement('col');
      col.style.width = '130px';
      colgroup.appendChild(col);
    }
    table.appendChild(colgroup);

    const tbody = document.createElement('tbody');
    table.appendChild(tbody);

    const addColBtn = document.createElement('button');
    addColBtn.type = 'button';
    addColBtn.className = 'q-add-col-btn';
    addColBtn.textContent = '+';
    addColBtn.title = 'Add column';

    flexRow.appendChild(table);
    flexRow.appendChild(addColBtn);

    const addRowBtn = document.createElement('button');
    addRowBtn.type = 'button';
    addRowBtn.className = 'q-add-row-btn';
    addRowBtn.textContent = '+';
    addRowBtn.title = 'Add row';

    outer.appendChild(flexRow);
    outer.appendChild(addRowBtn);

    function colCount(){ return colgroup.children.length - 1; }
    function rowCount(){ return tbody.children.length; }

    function syncHandles(){
      const tH = table.offsetHeight;
      const tW = table.offsetWidth;
      if(tH > 0){
        outer.querySelectorAll('.q-col-handle').forEach(h=>{ h.style.height = tH + 'px'; });
      }
      if(tW > 0){
        outer.querySelectorAll('.q-row-handle').forEach(h=>{ h.style.width = tW + 'px'; });
      }
    }
    outer._sync = syncHandles;

    function makeHeaderRow(){
      const tr = document.createElement('tr');
      tr.className = 'q-header-row';
      const corner = document.createElement('td');
      corner.className = 'q-ctrl-col';
      tr.appendChild(corner);
      for(let c=0; c<colCount(); c++){
        tr.appendChild(makeHeaderCell());
      }
      return tr;
    }

    function makeHeaderCell(){
      const td = document.createElement('td');
      const handle = document.createElement('div');
      handle.className = 'q-col-handle';
      const del = document.createElement('div');
      del.className = 'q-del-col';
      del.textContent = '×';
      del.title = 'Delete column';
      td.appendChild(handle);
      td.appendChild(del);
      attachColResize(handle);
      del.addEventListener('click', ()=> deleteColumn(td));
      return td;
    }

    function makeDataRow(){
      const tr = document.createElement('tr');
      const ctrl = document.createElement('td');
      ctrl.className = 'q-ctrl-col';
      const handle = document.createElement('div');
      handle.className = 'q-row-handle';
      const del = document.createElement('div');
      del.className = 'q-del-row';
      del.textContent = '×';
      del.title = 'Delete row';
      ctrl.appendChild(handle);
      ctrl.appendChild(del);
      attachRowResize(handle, tr);
      del.addEventListener('click', ()=> deleteRow(tr));
      tr.appendChild(ctrl);
      for(let c=0; c<colCount(); c++){
        tr.appendChild(makeDataCell());
      }
      return tr;
    }

    function makeDataCell(){
      const td = document.createElement('td');
      const cell = document.createElement('div');
      cell.className = 'q-cell';
      cell.contentEditable = 'true';
      td.appendChild(cell);
      return td;
    }

    function attachColResize(handle){
      let startX, col, startWidth;
      handle.addEventListener('mousedown', (e)=>{
        e.preventDefault();
        const td = handle.parentElement;
        const idx = Array.prototype.indexOf.call(td.parentElement.children, td);
        col = colgroup.children[idx];
        startX = e.clientX;
        startWidth = col.offsetWidth || parseInt(col.style.width) || 130;
        handle.classList.add('active');
        function onMove(ev){
          const delta = ev.clientX - startX;
          const newW = Math.max(50, startWidth + delta);
          col.style.width = newW + 'px';
        }
        function onUp(){
          handle.classList.remove('active');
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
          syncHandles();
        }
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });
    }

    function attachRowResize(handle, tr){
      let startY, startHeight;
      handle.addEventListener('mousedown', (e)=>{
        e.preventDefault();
        startY = e.clientY;
        startHeight = tr.offsetHeight || 36;
        handle.classList.add('active');
        function onMove(ev){
          const delta = ev.clientY - startY;
          const newH = Math.max(24, startHeight + delta);
          Array.from(tr.children).forEach(td => td.style.height = newH + 'px');
        }
        function onUp(){
          handle.classList.remove('active');
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
          syncHandles();
        }
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });
    }

    function deleteColumn(headerTd){
      if(colCount() <= 1) return;
      const idx = Array.prototype.indexOf.call(headerTd.parentElement.children, headerTd);
      colgroup.removeChild(colgroup.children[idx]);
      Array.from(tbody.children).forEach(tr=>{
        tr.removeChild(tr.children[idx]);
      });
      syncHandles();
    }

    function deleteRow(tr){
      if(rowCount() <= 2) return; // keep header + at least 1 data row
      tbody.removeChild(tr);
      syncHandles();
    }

    function addColumn(){
      const col = document.createElement('col');
      col.style.width = '130px';
      colgroup.appendChild(col);
      Array.from(tbody.children).forEach(tr=>{
        if(tr.classList.contains('q-header-row')){
          tr.appendChild(makeHeaderCell());
        } else {
          tr.appendChild(makeDataCell());
        }
      });
      syncHandles();
    }

    function addRow(){
      tbody.appendChild(makeDataRow());
      syncHandles();
    }

    // build initial structure
    tbody.appendChild(makeHeaderRow());
    for(let r=0; r<initialRows; r++){
      tbody.appendChild(makeDataRow());
    }

    addColBtn.addEventListener('mousedown', (e)=> e.preventDefault());
    addColBtn.addEventListener('click', addColumn);
    addRowBtn.addEventListener('mousedown', (e)=> e.preventDefault());
    addRowBtn.addEventListener('click', addRow);

    return outer;
  }

  const insertTableBtn = document.getElementById('insert-table-btn');
  insertTableBtn.addEventListener('mousedown', (e)=> e.preventDefault());
  insertTableBtn.addEventListener('click', ()=>{
    questionInput.focus();
    const widget = buildTableWidget(3, 3);
    const sel = window.getSelection();
    let range;
    if(sel && sel.rangeCount > 0 && questionInput.contains(sel.anchorNode)){
      range = sel.getRangeAt(0);
    } else {
      range = document.createRange();
      range.selectNodeContents(questionInput);
      range.collapse(false);
    }
    range.deleteContents();
    range.insertNode(widget);
    const br = document.createElement('br');
    widget.after(br);
    range.setStartAfter(br);
    range.collapse(true);
    sel.removeAllRanges();
    sel.addRange(range);
    if(widget._sync){
      widget._sync();
      requestAnimationFrame(()=> widget._sync());
    }
  });

  // ---- Answer options radio behavior ----
  document.querySelectorAll('.radio-dot').forEach(dot=>{
    dot.addEventListener('click', ()=>{
      const group = dot.dataset.group;
      document.querySelectorAll(`.radio-dot[data-group="${group}"]`).forEach(d=>d.classList.remove('picked'));
      dot.classList.add('picked');
    });
  });

  // ---- Retry queue filters (subject + error type, combined) ----
  const emptyState = document.getElementById('empty-state');
  const overdueOnlyBox = document.getElementById('overdue-only');
  const filterState = { subject: 'all', error: 'all' };

  function applyQueueFilters(){
    const overdueOnly = overdueOnlyBox.checked;
    const queueItems = document.querySelectorAll('#queue-list .queue-item');
    let visibleCount = 0;

    queueItems.forEach(item=>{
      let show = true;
      if(filterState.subject !== 'all' && item.dataset.subject !== filterState.subject) show = false;
      if(filterState.error !== 'all'){
        const types = item.dataset.types.split(' ');
        if(!types.includes(filterState.error)) show = false;
      }
      if(overdueOnly && item.dataset.overdue !== 'true') show = false;
      item.classList.toggle('hidden', !show);
      if(show) visibleCount++;
    });

    if(queueItems.length > 0){
      emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
    }
  }

  document.querySelectorAll('.filter-row').forEach(row=>{
    const group = row.dataset.group;
    row.querySelectorAll('.filter-chip').forEach(chip=>{
      chip.addEventListener('click', ()=>{
        row.querySelectorAll('.filter-chip').forEach(c=>c.classList.remove('on'));
        chip.classList.add('on');
        filterState[group] = chip.dataset.filter;
        applyQueueFilters();
      });
    });
  });

  overdueOnlyBox.addEventListener('change', applyQueueFilters);

  // ---- Heatmap mock data ----
  const subjects = ['Fixed Income','Equity','FRA','Ethics','Quant','Derivatives','Economics','Alt Investments'];
  const errTypes = ['Concept','Calc','Read','Trap','Forgot'];
  const heat = [
    [9,7,2,1,3],
    [3,2,5,4,1],
    [2,1,6,2,2],
    [1,1,2,8,1],
    [4,8,1,1,2],
    [6,3,1,3,2],
    [5,4,2,2,1],
    [2,1,3,3,4]
  ];
  function heatColor(v){
    const max = 9; const t = v/max;
    return `rgba(143,168,194,${0.08 + t*0.55})`;
  }
  const hmEl = document.getElementById('heatmap');
  let hmHtml = `<div></div>`;
  errTypes.forEach(e=> hmHtml += `<div class="collabel">${e}</div>`);
  subjects.forEach((s,ri)=>{
    hmHtml += `<div class="rowlabel">${s}</div>`;
    errTypes.forEach((e,ci)=>{
      const v = heat[ri][ci];
      hmHtml += `<div class="hcell" style="background:${heatColor(v)};">${v}</div>`;
    });
  });
  hmEl.innerHTML = hmHtml;

  // ---- Bar list mock data ----
  const bars = [
    {label:'Conceptual gap', pct:41},
    {label:'Calculation error', pct:26},
    {label:'Misread question', pct:16},
    {label:'Trap / distractor', pct:13},
    {label:'Forgot', pct:4},
  ];
  document.getElementById('bar-list').innerHTML = bars.map(b=>`
    <div class="bar-row">
      <div class="bar-top"><span>${b.label}</span><span>${b.pct}%</span></div>
      <div class="bar-track"><div class="bar-fill" style="width:${b.pct}%;"></div></div>
    </div>
  `).join('');

  // ---- Trend line mock data ----
  const weeks = [12,15,11,9,10,7,8,6];
  const svg = document.getElementById('trend-svg');
  const w = 600, h = 150, pad = 20;
  const maxV = Math.max(...weeks);
  const stepX = (w - pad*2) / (weeks.length - 1);
  let points = weeks.map((v,i)=>{
    const x = pad + i*stepX;
    const y = h - pad - (v/maxV)*(h - pad*2);
    return [x,y];
  });
  let path = 'M' + points.map(p=>p.join(',')).join(' L');
  let svgContent = `
    <line x1="${pad}" y1="${h-pad}" x2="${w-pad}" y2="${h-pad}" stroke="#2a2a30" stroke-width="1"/>
    <path d="${path}" fill="none" stroke="#8fa8c2" stroke-width="2"/>
  `;
  points.forEach(p=>{
    svgContent += `<circle cx="${p[0]}" cy="${p[1]}" r="3.5" fill="#8fa8c2"/>`;
  });
  svg.innerHTML = svgContent;
</script>

</body>
</html>
