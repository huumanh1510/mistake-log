  async function submitRetryResult(id, wasCorrect){
    const mistake = allMistakes.find(m=> m.id === id);
    if(!mistake) return;
    const history = (mistake.retryHistory || []).slice();
    history.push({ date: new Date().toISOString(), result: wasCorrect ? 'pass' : 'fail' });

    let consecutivePass = 0;
    for(let i = history.length - 1; i >= 0; i--){
      if(history[i].result === 'pass') consecutivePass++; else break;
    }

    const updates = { retryHistory: history };
    if(!wasCorrect){
      updates.nextReviewAt = firebase.firestore.Timestamp.fromDate(new Date(Date.now() + 1*24*60*60*1000));
      updates.status = 'unresolved';
    } else if(consecutivePass >= 3){
      updates.status = 'resolved';
    } else {
      const days = consecutivePass === 1 ? 2 : 5;
      updates.nextReviewAt = firebase.firestore.Timestamp.fromDate(new Date(Date.now() + days*24*60*60*1000));
      updates.status = 'unresolved';
    }

    try{
      await mistakesCollection().doc(id).update(updates);
      showToast(updates.status === 'resolved' ? 'Mastered — nice work' : 'Rescheduled');
    } catch(err){
      console.error('[Firestore]', err.message);
      showToast('Could not update: ' + err.message, true);
    }
