  function buildReviewPanelHtml(m){
    const opts = m.options || {};
    return `
      <div class="review-panel">
        <div class="rp-block"><div class="rp-label">Question</div><div class="rp-value">${m.questionHtml}</div></div>
        <div class="rp-block"><div class="rp-label">Options</div>
          <div class="rp-value">A. ${opts.A||''}</div>
          <div class="rp-value">B. ${opts.B||''}</div>
          <div class="rp-value">C. ${opts.C||''}</div>
        </div>
        <div class="rp-block"><div class="rp-label">Correct answer</div><div class="rp-value rp-correct">${m.correctAnswer||'—'}</div></div>
        ${m.explanation ? `<div class="rp-block"><div class="rp-label">Explanation</div><div class="rp-value">${m.explanation}</div></div>` : ''}
