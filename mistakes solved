  function renderRetryQueue(){
    const list = document.getElementById('queue-list');
    const active = allMistakes.filter(m=> m.status !== 'resolved');
    active.sort((a,b)=>{
      const da = a.nextReviewAt && a.nextReviewAt.toDate ? a.nextReviewAt.toDate().getTime() : 0;
      const db = b.nextReviewAt && b.nextReviewAt.toDate ? b.nextReviewAt.toDate().getTime() : 0;
      return da - db;
    });

    if(active.length === 0){
      list.innerHTML = '';
      document.getElementById('empty-state').style.display = 'block';
      return;
    }

    list.innerHTML = active.map(m=>{
      const due = formatDue(m.nextReviewAt);
      const subjectKey = SUBJECT_KEY[m.subject] || 'other';
      const typesAttr = (m.errorTypes||[]).join(' ');
      const preview = stripHtml(m.questionHtml).slice(0, 110) || '(no question text)';
      const tagsHtml = (m.errorTypes||[]).map(t=>`<span class="mini-tag">${ERROR_LABEL[t]||t}</span>`).join('');
