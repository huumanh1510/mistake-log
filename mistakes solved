  function formatDue(nextReviewAt){
    if(!nextReviewAt || !nextReviewAt.toDate) return { label:'Due soon', overdue:false };
    const due = nextReviewAt.toDate();
    const now = new Date();
    const diffMs = due.getTime() - now.getTime();
    const diffH = diffMs / (1000*60*60);
    if(diffH <= 0){
      const overdueDays = Math.max(1, Math.round(-diffH/24));
      return { label: overdueDays + 'd overdue', overdue:true };
    }
    if(diffH < 24) return { label: 'Due in ' + Math.ceil(diffH) + 'h', overdue:false };
    return { label: 'Due in ' + Math.ceil(diffH/24) + 'd', overdue:false };
  }

  function stripHtml(html){
    const tmp = document.createElement('div');
    tmp.innerHTML = html;
    return (tmp.textContent || '').trim();
