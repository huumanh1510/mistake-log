<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mistake Log — CFA Review</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>
<style>
  :root{
    --bg: #0a0a0c;
    --surface: #131317;
    --surface-2: #1a1a1f;
    --line: #2a2a30;
    --text: #e9e9ec;
    --text-dim: #7a7a83;
    --text-faint: #4d4d54;
    --accent: #8fa8c2;
    --accent-dim: #8fa8c22b;
    --font: 'Be Vietnam Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  body{
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    min-height:100vh;
    padding-bottom: 60px;
  }

  header{
    padding: 30px 32px 22px;
    border-bottom:1px solid var(--line);
    display:flex; align-items:baseline; justify-content:space-between; flex-wrap:wrap; gap:10px;
  }
  .brand{ display:flex; align-items:baseline; gap:10px; }
  .brand .mark{ font-weight:700; font-size:1.15rem; letter-spacing:.01em; color:var(--text);}
  .brand .dot{ color: var(--accent); }
  .brand .sub{ color:var(--text-dim); font-size:.78rem; letter-spacing:.05em; text-transform:uppercase; margin-left:4px;}
  .meta-stat{ font-size:.8rem; color:var(--text-dim); border:1px solid var(--line); border-radius:3px; padding:5px 12px; }
  .meta-stat b{ color:var(--text); font-weight:700; }

  nav.tabs{ display:flex; gap:2px; padding: 0 32px; border-bottom:1px solid var(--line); overflow-x:auto; }
  nav.tabs button{
    background:none; border:none; color:var(--text-dim); font-family:var(--font);
    font-size:.88rem; padding:16px 18px; cursor:pointer; position:relative; white-space:nowrap;
  }
  nav.tabs button.active{ color:var(--text); }
  nav.tabs button.active::after{
    content:''; position:absolute; bottom:-1px; left:18px; right:18px; height:1px; background: var(--accent);
  }
  nav.tabs button .count{
    background: var(--surface-2); color:var(--text-dim); border-radius:3px; font-size:.7rem;
    padding:1px 6px; margin-left:7px;
  }

  main{ padding: 32px; max-width: 1080px; margin: 0 auto;}
  .panel{ display:none; }
  .panel.active{ display:block; }

  h2.section-title{ font-size:1.1rem; font-weight:700; color:var(--text); margin-bottom:5px; }
  p.section-hint{ color:var(--text-dim); font-size:.85rem; margin-bottom:22px; }

  /* ---------- FORM ---------- */
  .card{ background: var(--surface); border:1px solid var(--line); border-radius:6px; padding:24px; }
  .grid2{ display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  .field{ margin-bottom:18px; }
  .field label{ display:block; font-size:.74rem; color:var(--text-dim); margin-bottom:7px; letter-spacing:.03em; text-transform:uppercase;}
  .field select, .field input, .field textarea{
    width:100%; background:var(--surface-2); border:1px solid var(--line); color:var(--text);
    border-radius:4px; padding:10px 12px; font-family:var(--font); font-size:.92rem;
  }
  .field select:focus, .field input:focus, .field textarea:focus{ outline:none; border-color: var(--accent); }
  .field textarea{ min-height:64px; resize:vertical; }
  .divider{ height:1px; background:var(--line); margin: 22px 0; }
  .subhead{ font-size:.74rem; color:var(--text-faint); letter-spacing:.05em; text-transform:uppercase; margin-bottom:14px; }

  /* ---------- Question editor ---------- */
  .editor-wrap{ border:1px solid var(--line); border-radius:4px; overflow:hidden; }
  .editor-wrap:focus-within{ border-color: var(--accent); }
  .editor-toolbar{
    display:flex; align-items:center; gap:4px; background:var(--surface-2);
    border-bottom:1px solid var(--line); padding:6px 8px;
  }
  .editor-toolbar button{
    background:transparent; border:1px solid transparent; border-radius:3px;
    color:var(--text-dim); font-family:var(--font); font-size:.85rem;
    width:28px; height:26px; cursor:pointer; display:flex; align-items:center; justify-content:center;
  }
  .editor-toolbar button:hover{ border-color:var(--line); color:var(--text); }
  .editor-toolbar button.table-btn{ width:auto; padding:0 10px; font-size:.76rem; }
  .editor-toolbar .tb-divider{ width:1px; height:16px; background:var(--line); margin:0 4px; }
  .question-input{
    width:100%; min-height:240px; max-height:520px; background:var(--surface-2);
    padding:14px 16px; font-family:var(--font); font-size:.92rem;
    line-height:1.6; overflow-y:auto; overflow-x:auto;
  }
  .question-input, .question-input > *:not(.q-table-outer):not(.q-table-outer *){
    color: var(--text) !important;
    background-color: transparent !important;
  }
  .question-input:focus{ outline:none; }
  .question-input:empty::before{ content: attr(data-placeholder); color:var(--text-faint) !important; }
  .paste-hint{ font-size:.72rem; color:var(--text-faint); margin-top:6px; }

  /* ---------- Notion-like editable table widget ---------- */
  .q-table-outer{
    margin: 10px 0; user-select:none;
  }
  .q-table-outer, .q-table-outer *{ color: var(--text) !important; }
  .q-table-flex{ display:flex; flex-direction:row; align-items:stretch; }
  table.q-table{
    border-collapse:collapse; table-layout:fixed;
  }
  table.q-table td{
    border:1px solid var(--line); padding:6px 10px; font-size:.86rem; vertical-align:top;
    background:var(--surface-2) !important; position:relative;
  }
  .q-ctrl-col{
    width:16px; min-width:16px; max-width:16px;
    background:var(--surface) !important; border-color:var(--line);
  }
  .q-header-row td{
    height:14px; padding:0; background:var(--surface) !important; border-bottom:1px solid var(--line);
  }
  .q-cell{ outline:none; min-height:20px; user-select:text; }
  .q-cell:focus{ background:var(--surface-2); }

  .q-col-handle, .q-row-handle{ position:absolute; }
  .q-col-handle{ top:0; right:-3px; width:6px; height:120px; cursor:col-resize; z-index:6; }
  .q-col-handle:hover, .q-col-handle.active{ background: var(--accent-dim); }
  .q-row-handle{ left:0; bottom:-3px; height:6px; width:300px; cursor:row-resize; z-index:6; }
  .q-row-handle:hover, .q-row-handle.active{ background: var(--accent-dim); }

  .q-del-col, .q-del-row{
    position:absolute; opacity:0; transition:opacity .1s;
    width:14px; height:14px; border-radius:3px; background:var(--surface); border:1px solid var(--line);
    color:var(--text-dim) !important; font-size:.6rem; line-height:12px; text-align:center; cursor:pointer; z-index:7;
  }
  .q-header-row td:hover .q-del-col{ opacity:1; }
  .q-ctrl-col:hover .q-del-row{ opacity:1; }
  .q-del-col{ top:0; left:50%; transform:translateX(-50%); }
  .q-del-row{ left:1px; top:50%; transform:translateY(-50%); }

  .q-add-col-btn{
    flex-shrink:0; width:22px; align-self:stretch; background:var(--surface) !important;
    border:1px solid var(--line); border-left:none; color:var(--text-dim) !important;
    cursor:pointer; font-size:.85rem;
  }
  .q-add-col-btn:hover{ background:var(--surface-2) !important; color:var(--text) !important; }
  .q-add-row-btn{
    width:100%; height:20px; background:var(--surface) !important;
    border:1px solid var(--line); border-top:none; color:var(--text-dim) !important;
    cursor:pointer; font-size:.8rem;
  }
  .q-add-row-btn:hover{ background:var(--surface-2) !important; color:var(--text) !important; }

  /* ---------- ANSWER OPTIONS ---------- */
  .options-block{ border:1px solid var(--line); border-radius:6px; overflow:hidden; }
  .options-header{
    display:grid; grid-template-columns: 1fr 90px 90px;
    padding:10px 16px; background:var(--surface-2);
    font-size:.7rem; color:var(--text-dim); letter-spacing:.04em; text-transform:uppercase;
  }
  .options-header span:nth-child(2), .options-header span:nth-child(3){ text-align:center; }
  .option-row{
    display:grid; grid-template-columns: 1fr 90px 90px; align-items:center;
    padding:10px 16px; border-top:1px solid var(--line);
    transition: background .12s;
  }
  .option-row:hover{ background: var(--surface-2); }
  .option-left{ display:flex; align-items:center; gap:12px; }
  .opt-letter{
    width:24px; height:24px; border-radius:50%; border:1px solid var(--line);
    display:flex; align-items:center; justify-content:center; font-size:.78rem; color:var(--text-dim);
    flex-shrink:0;
  }
  .option-left input{
    flex:1; background:transparent; border:none; border-bottom:1px solid transparent;
    color:var(--text); font-family:var(--font); font-size:.9rem; padding:4px 2px;
  }
  .option-left input:focus{ outline:none; border-bottom-color:var(--accent); }
  .radio-cell{ display:flex; justify-content:center; }
  .radio-dot{
    width:18px; height:18px; border-radius:50%; border:1px solid var(--line);
    cursor:pointer; position:relative; flex-shrink:0;
  }
  .radio-dot.picked{ border-color: var(--accent); }
  .radio-dot.picked::after{
    content:''; position:absolute; inset:4px; border-radius:50%; background: var(--accent);
  }
  .options-footnote{ font-size:.72rem; color:var(--text-faint); margin-top:10px; }

  .tag-row{ display:flex; flex-wrap:wrap; gap:8px; }
  .tag{
    border:1px solid var(--line); border-radius:4px; padding:7px 14px; font-size:.82rem;
    cursor:pointer; color:var(--text-dim); user-select:none; background:var(--surface-2);
  }
  .tag.on{ background:var(--accent-dim); border-color:var(--accent); color:var(--text); }

  .btn-primary{
    background: var(--text); color:var(--bg); border:none; border-radius:4px;
    padding:11px 20px; font-weight:700; font-size:.87rem; cursor:pointer; margin-top:4px;
    font-family:var(--font);
  }
  .btn-primary:hover{ background:#fff; }

  /* ---------- RETRY QUEUE ---------- */
  .queue-item{
    display:flex; align-items:center; gap:14px; background:var(--surface);
    border:1px solid var(--line); border-radius:6px; padding:14px 16px; margin-bottom:8px;
  }
  .queue-item.hidden{ display:none; }
  .queue-item .status-bar{ width:3px; align-self:stretch; border-radius:2px; background:var(--line); flex-shrink:0; }
  .queue-item.overdue .status-bar{ background: var(--text); }
  .queue-item .meta{ flex:1; }
  .queue-item .subject-badge{ font-size:.7rem; color:var(--text-dim); display:inline-block; margin-bottom:5px; letter-spacing:.02em;}
  .queue-item .q-text{ font-size:.9rem; color:var(--text); }
  .queue-item .err-tags{ margin-top:7px; display:flex; gap:6px; flex-wrap:wrap;}
  .mini-tag{ font-size:.7rem; padding:2px 8px; border-radius:3px; border:1px solid var(--line); color:var(--text-dim);}
  .queue-item .due{ font-size:.76rem; color:var(--text-dim); white-space:nowrap; }
  .queue-item .due.urgent{ color:var(--text); }
  .btn-mini{
    background:none; border:1px solid var(--line); color:var(--text); border-radius:4px;
    padding:8px 14px; font-size:.8rem; cursor:pointer; white-space:nowrap; font-family:var(--font);
  }
  .btn-mini:hover{ border-color: var(--accent); }
  .filter-groups{ margin-bottom:20px; }
  .filter-group{ margin-bottom:12px; }
  .filter-group:last-of-type{ margin-bottom:14px; }
  .filter-label{
    display:block; font-size:.7rem; color:var(--text-faint); text-transform:uppercase;
    letter-spacing:.05em; margin-bottom:7px;
  }
  .filter-row{ display:flex; gap:8px; flex-wrap:wrap; }
  .filter-chip{
    font-size:.78rem; border:1px solid var(--line); color:var(--text-dim); border-radius:4px;
    padding:6px 13px; cursor:pointer;
  }
  .filter-chip.on{ background:var(--surface-2); color:var(--text); border-color:var(--accent); }
  .overdue-toggle{
    display:flex; align-items:center; gap:8px; font-size:.8rem; color:var(--text-dim); cursor:pointer; width:fit-content;
  }
  .overdue-toggle input{ accent-color: var(--accent); width:15px; height:15px; cursor:pointer; }
  .empty-state{ color:var(--text-faint); font-size:.85rem; padding:24px; text-align:center; border:1px dashed var(--line); border-radius:6px; }

  /* ---------- ANALYTICS ---------- */
  .stat-row{ display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:24px;}
  .stat-card{ background:var(--surface); border:1px solid var(--line); border-radius:6px; padding:16px 18px;}
  .stat-card .num{ font-size:1.6rem; color:var(--text); font-weight:700;}
  .stat-card .lbl{ font-size:.74rem; color:var(--text-dim); text-transform:uppercase; letter-spacing:.03em; margin-top:3px;}

  .analytics-grid{ display:grid; grid-template-columns: 1.3fr 1fr; gap:16px; margin-bottom:16px; }
  .chart-card{ background:var(--surface); border:1px solid var(--line); border-radius:6px; padding:20px;}
  .chart-card h3{ font-size:.82rem; margin-bottom:16px; font-weight:700; color:var(--text-dim); text-transform:uppercase; letter-spacing:.03em;}

  .heatmap{ display:grid; grid-template-columns: 90px repeat(5, 1fr); gap:3px; font-size:.72rem;}
  .heatmap .hcell{ padding:9px 4px; text-align:center; border-radius:3px; color:var(--text);}
  .heatmap .rowlabel{ text-align:right; padding-right:8px; color:var(--text-dim); display:flex; align-items:center; justify-content:flex-end; font-size:.76rem;}
  .heatmap .collabel{ text-align:center; color:var(--text-dim); padding-bottom:6px; }

  .bar-track{ background:var(--surface-2); border-radius:3px; height:8px; overflow:hidden; margin-top:5px;}
  .bar-fill{ height:100%; border-radius:3px; background: var(--text-dim); }
  .bar-row{ margin-bottom:15px; }
  .bar-row .bar-top{ display:flex; justify-content:space-between; font-size:.82rem; margin-bottom:4px;}
  .bar-row .bar-top span:last-child{ color:var(--text-dim); }

  .trend-svg{ width:100%; height:150px; }

  /* ---------- SUGGESTIONS ---------- */
  .suggestion{ background:var(--surface); border:1px solid var(--line); border-radius:6px; padding:18px 20px; margin-bottom:10px; }
  .suggestion .sug-title{ font-weight:700; font-size:.92rem; margin-bottom:6px; color:var(--text);}
  .suggestion .sug-body{ font-size:.85rem; color:var(--text-dim); line-height:1.55;}
  .suggestion .sug-tag{ font-size:.68rem; color:var(--text-faint); text-transform:uppercase; letter-spacing:.04em; margin-bottom:8px; display:block; }

  @media (max-width: 700px){
    .grid2{ grid-template-columns:1fr; }
    .stat-row{ grid-template-columns:repeat(2,1fr); }
    .analytics-grid{ grid-template-columns:1fr; }
    header, nav.tabs, main{ padding-left:18px; padding-right:18px; }
    .options-header, .option-row{ grid-template-columns: 1fr 70px 70px; }
  }

  /* ---------- LOGIN SCREEN ---------- */
  #login-screen{
    min-height:100vh; display:flex; align-items:center; justify-content:center; flex-direction:column; gap:22px;
  }
  #login-screen.hidden{ display:none; }
  #login-screen .login-mark{ font-size:1.4rem; font-weight:700; }
  #login-screen .login-mark .dot{ color:var(--accent); }
  #login-screen .login-sub{ color:var(--text-dim); font-size:.88rem; }
  #login-btn{
    background:var(--surface); border:1px solid var(--line); color:var(--text);
    font-family:var(--font); font-size:.9rem; padding:12px 24px; border-radius:6px; cursor:pointer;
    display:flex; align-items:center; gap:10px;
  }
  #login-btn:hover{ border-color:var(--accent); }
  #login-btn:disabled{ opacity:.5; cursor:default; }
  #login-err{ display:none; color:#c97b7b; font-size:.8rem; max-width:340px; text-align:center; }
  #login-loading{ display:none; color:var(--text-dim); font-size:.82rem; }
  #login-loading.show{ display:block; }

  #app-shell{ display:none; }
  #app-shell.visible{ display:block; }

  .user-pill{ display:flex; align-items:center; gap:8px; font-size:.8rem; color:var(--text-dim); }
  .user-pill .u-name{ color:var(--text); }
  .user-pill button{
    background:none; border:1px solid var(--line); color:var(--text-dim); border-radius:4px;
    padding:4px 10px; font-size:.76rem; cursor:pointer; font-family:var(--font);
  }
  .user-pill button:hover{ border-color:var(--accent); color:var(--text); }

  .toast{
    position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(20px);
    background:var(--surface); border:1px solid var(--line); color:var(--text);
    padding:10px 20px; border-radius:6px; font-size:.85rem; opacity:0; pointer-events:none;
    transition: all .2s; z-index:100;
  }
  .toast.show{ opacity:1; transform:translateX(-50%) translateY(0); }
  .toast.error{ border-color:#c97b7b; color:#e0a0a0; }

  /* ---------- Retry review panel ---------- */
  .review-panel{
    margin-top:10px; padding-top:12px; border-top:1px solid var(--line);
    font-size:.85rem; color:var(--text-dim); line-height:1.55;
  }
  .review-panel .rp-block{ margin-bottom:10px; }
  .review-panel .rp-label{ font-size:.68rem; text-transform:uppercase; letter-spacing:.04em; color:var(--text-faint); margin-bottom:3px; }
  .review-panel .rp-value{ color:var(--text); }
  .review-panel .rp-correct{ color:var(--accent); }
  .review-actions{ display:flex; gap:8px; margin-top:10px; }
  .btn-correct, .btn-wrong{
    flex:1; padding:9px; border-radius:4px; font-size:.82rem; cursor:pointer; font-family:var(--font);
    border:1px solid var(--line); background:var(--surface-2); color:var(--text);
  }
  .btn-correct:hover{ border-color:var(--accent); }
  .btn-wrong:hover{ border-color:#c97b7b; }
</style>
</head>
<body>

<div id="login-screen">
  <div class="login-mark">Mistake Log<span class="dot">.</span></div>
  <div class="login-sub">Sign in with the same Google account you use for CFA Ninja</div>
  <button id="login-btn" onclick="signIn()">Sign in with Google</button>
  <div id="login-loading">Opening Google sign-in…</div>
  <div id="login-err"></div>
</div>

<div id="app-shell">

<header>
  <div class="brand">
    <span class="mark">Mistake Log<span class="dot">.</span></span>
    <span class="sub">CFA Exam Review</span>
  </div>
  <div style="display:flex; align-items:center; gap:14px;">
    <div class="meta-stat"><b id="stat-unresolved">0</b> unresolved · <b id="stat-resolve-rate">—</b> resolve rate</div>
    <div class="user-pill" id="user-pill">
      <span class="u-name" id="user-name"></span>
      <button onclick="signOutUser()">Sign out</button>
    </div>
  </div>
</header>

<nav class="tabs">
  <button class="active" data-tab="log">Log Mistake</button>
  <button data-tab="queue">Retry Queue <span class="count">14</span></button>
  <button data-tab="analytics">Analytics</button>
  <button data-tab="suggest">Suggestions</button>
</nav>

<main>

  <!-- ============ TAB 1: LOG MISTAKE ============ -->
  <section class="panel active" id="tab-log">
    <h2 class="section-title">Log a new mistake</h2>
    <p class="section-hint">Enter this right after you get it wrong — details fade fast.</p>
    <div class="card">
      <div class="grid2">
        <div class="field">
          <label>Subject</label>
          <select id="f-subject">
            <option>Fixed Income</option>
            <option>Equity Investments</option>
            <option>Financial Statement Analysis</option>
            <option>Quantitative Methods</option>
            <option>Economics</option>
            <option>Ethics & Professional Standards</option>
            <option>Portfolio Management</option>
            <option>Derivatives</option>
            <option>Alternative Investments</option>
            <option>Corporate Issuers</option>
          </select>
        </div>
        <div class="field">
          <label>Topic / LOS</label>
          <input type="text" id="f-topic" placeholder="e.g. Bond convexity & duration">
        </div>
      </div>

      <div class="field">
        <label>Question</label>
        <div class="editor-wrap">
          <div class="editor-toolbar">
            <button type="button" data-cmd="bold" title="Bold"><b>B</b></button>
            <button type="button" data-cmd="italic" title="Italic"><i>I</i></button>
            <span class="tb-divider"></span>
            <button type="button" class="table-btn" id="insert-table-btn" title="Insert table">+ Table</button>
          </div>
          <div class="question-input" id="question-input" contenteditable="true" data-placeholder="Paste the question here — text always stays readable, and you can insert a table below..."></div>
        </div>
        <div class="paste-hint">Pasted text is cleaned up so it always shows up in the theme's colors. Tables are fully editable — resize columns/rows and add or remove them like in Notion.</div>
      </div>

      <div class="field">
        <label>Answer options</label>
        <div class="options-block">
          <div class="options-header">
            <span>Option text</span><span>Your pick</span><span>Correct</span>
          </div>
          <div class="option-row" data-letter="A">
            <div class="option-left"><span class="opt-letter">A</span><input type="text" id="f-opt-a" placeholder="Option A"></div>
            <div class="radio-cell"><span class="radio-dot" data-group="chosen" data-value="A"></span></div>
            <div class="radio-cell"><span class="radio-dot" data-group="correct" data-value="A"></span></div>
          </div>
          <div class="option-row" data-letter="B">
            <div class="option-left"><span class="opt-letter">B</span><input type="text" id="f-opt-b" placeholder="Option B"></div>
            <div class="radio-cell"><span class="radio-dot" data-group="chosen" data-value="B"></span></div>
            <div class="radio-cell"><span class="radio-dot" data-group="correct" data-value="B"></span></div>
          </div>
