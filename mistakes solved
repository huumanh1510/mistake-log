  // ============================================================
  const questionInput = document.getElementById('question-input');
  const STRUCTURAL_TAGS = ['UL','OL','LI','BR','P','DIV'];

  function sanitizeNode(node){
    if(node.nodeType === Node.TEXT_NODE){
      return document.createTextNode(node.textContent);
    }
    if(node.nodeType !== Node.ELEMENT_NODE){
      return document.createDocumentFragment();
    }
    const tag = node.tagName;
    // tables pasted from elsewhere become plain text content (structure is created via the + Table button instead)
    if(tag === 'TABLE'){
      const text = node.textContent.trim();
      return document.createTextNode(text);
    }
    const style = node.getAttribute('style') || '';
    const isBold = tag === 'B' || tag === 'STRONG' || /font-weight\s*:\s*(bold|[6-9]00)/i.test(style);
    const isItalic = tag === 'I' || tag === 'EM' || /font-style\s*:\s*italic/i.test(style);

    const frag = document.createDocumentFragment();
    node.childNodes.forEach(child => frag.appendChild(sanitizeNode(child)));

    let content = frag;
    if(isItalic){ const em = document.createElement('em'); em.appendChild(content); content = em; }
    if(isBold){ const strong = document.createElement('strong'); strong.appendChild(content); content = strong; }

    if(STRUCTURAL_TAGS.includes(tag)){
      const el = document.createElement(tag);
      el.appendChild(content);
      return el;
    }
    return content;
  }

  function sanitizeHTML(html){
    const doc = new DOMParser().parseFromString(html, 'text/html');
    const frag = document.createDocumentFragment();
    doc.body.childNodes.forEach(child => frag.appendChild(sanitizeNode(child)));
    const wrapper = document.createElement('div');
    wrapper.appendChild(frag);
    return wrapper.innerHTML;
  }

  questionInput.addEventListener('paste', (e)=>{
