    const html = clipboard.getData('text/html');
    let clean;
    if(html){
      clean = sanitizeHTML(html);
    } else {
      const text = clipboard.getData('text/plain');
      clean = text
        .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
        .split('\n').join('<br>');
    }
    document.execCommand('insertHTML', false, clean);
  });

